{
    "name": "lumen-unified-backend",
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "npx tsx src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "mock:render": "npx tsx src/mock-render/server.ts",
        "postinstall": "node -v && prisma generate && (chmod +x ./lumen || true)",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
    },
    "dependencies": {
        "@fastify/cors": "^8.5.0",
        "@fastify/websocket": "^8.2.0",
        "@google/generative-ai": "^0.24.1",
        "@prisma/client": "^5.22.0",
        "@types/dockerode": "^3.3.19",
        "@types/node": "^20.5.0",
        "@types/uuid": "^9.0.2",
        "axios": "^1.14.0",
        "dockerode": "^4.0.0",
        "dotenv": "^17.3.1",
        "fastify": "^4.21.0",
        "fluent-json-schema": "^4.2.1",
        "groq-sdk": "^1.1.2",
        "lucide-react": "^1.7.0",
        "node-cron": "^4.2.1",
        "os-browserify": "^0.3.0",
        "path-browserify": "^1.0.1",
        "prisma": "^5.0.0",
        "sanitize-html": "^2.17.2",
        "typescript": "^5.1.6",
        "uuid": "^9.0.0",
        "zod": "^3.21.4"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node-cron": "^3.0.11",
        "@types/sanitize-html": "^2.16.1",
        "@types/supertest": "^7.2.0",
        "jest": "^30.3.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.1",
        "tsx": "^4.21.0"
    }
