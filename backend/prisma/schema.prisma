generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Package {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  owner       String    // GitHub username or ID
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  versions    Version[]
}

model Version {
  id        String   @id @default(uuid())
  version   String   // semver
  packageId String
  package   Package  @relation(fields: [packageId], references: [id])
  tarball   String   // S3 URL
  checksum  String   // SHA-256
  createdAt DateTime @default(now())

  @@unique([packageId, version])
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  apiKey         String          @unique
  deploySessions DeploySession[]
  createdAt      DateTime        @default(now())
}

enum DeployStatus {
  scanning
  config_ready
  deploying
  live
  failed
}

enum LogLevel {
  info
  warn
  error
}

model DeploySession {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  repoUrl         String?
  scanResult      Json? // Raw Gemini scanner output
  lumenConfig     String? // Generated .lumen config string
  renderServiceId String? // Render service ID once deployed
  status          DeployStatus @default(scanning)
  logs            DeployLog[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model DeployLog {
  id        String        @id @default(uuid())
  sessionId String
  session   DeploySession @relation(fields: [sessionId], references: [id])
  line      String
  level     LogLevel      @default(info)
  timestamp DateTime      @default(now())
}
