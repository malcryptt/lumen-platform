{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Lumen",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.lumen",
                    "match": "\\b(fn|let|val|const|class|struct|enum|type|if|else|elif|for|while|return|import|export|async|await|yield|match|with|defer|guard|raise|try|catch|finally|in|end|pub|mut|self|super|use|break|continue|do)\\b"
                },
                {
                    "name": "keyword.operator.logical.lumen",
                    "match": "\\b(and|or|not|is|as|nil|void)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.lumen",
                    "match": "\\b(Int|Int8|Int16|Int32|Int64|Float|Float32|Float64|String|Bool|List|Map|Set|bytes|Result|Option|Any|Never|Tuple|Channel)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.lumen",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.lumen",
                            "match": "\\\\."
                        },
                        {
                            "name": "variable.other.interpolation.lumen",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                {
                                    "include": "source.lumen"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.lumen",
                    "match": "'[^'\\\\]*'"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-dash.lumen",
                    "match": "--.*$"
                },
                {
                    "name": "comment.block.lumen",
                    "begin": "--\\[\\[",
                    "end": "\\]\\]"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.lumen",
                    "match": "\\b(true|false|nil)\\b"
                },
                {
                    "name": "constant.numeric.integer.lumen",
                    "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?\\b"
                },
                {
                    "name": "constant.numeric.hex.lumen",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.lumen",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
                },
                {
                    "name": "entity.name.type.class.lumen",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.lumen",
                    "match": "(\\.\\.|\\.\\.|=>|->|\\|>|::|<<|>>|&&|\\|\\||[+\\-*/%&|^~<>=!]=?)"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.lumen",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b"
                }
            ]
        }
    },
    "scopeName": "source.lumen"
}