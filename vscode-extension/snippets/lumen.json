{
    "Lumen Function": {
        "prefix": "fn",
        "body": [
            "fn ${1:name}(${2:args}) {",
            "\t$0",
            "}"
        ],
        "description": "Define a function"
    },
    "Lumen Class": {
        "prefix": "class",
        "body": [
            "class ${1:Name} {",
            "\tfn init() {",
            "\t\t$0",
            "\t}",
            "}"
        ],
        "description": "Define a class"
    },
    "Lumen If Statement": {
        "prefix": "if",
        "body": [
            "if ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "If statement"
    },
    "Lumen For Loop": {
        "prefix": "for",
        "body": [
            "for ${1:item} in ${2:iterable} {",
            "\t$0",
            "}"
        ],
        "description": "For loop"
    },
    "Lumen Async Function": {
        "prefix": "async",
        "body": [
            "async fn ${1:name}(${2:args}) {",
            "\t$0",
            "}"
        ],
        "description": "Define an async function"
    },
    "Lumen Guard": {
        "prefix": "guard",
        "body": [
            "guard ${1:condition} else {",
            "\treturn $0",
            "}"
        ],
        "description": "Guard statement"
    }
}